         return len(self.ids)
 
     def _path(self, ecg_id):
-        for name in (f"{ecg_id}.png", f"{int(ecg_id):05d}.png", f"{ecg_id}.jpg"):
+        # Candidates are built lazily: PTB-XL ids are integers and rendered
+        # zero-padded, but Challenge 2020 ids are strings ('A0147', 'HR00001').
+        # Formatting the whole tuple eagerly made int('A0147') raise before the
+        # loop could test the name that actually exists.
+        candidates = [f"{ecg_id}.png"]
+        try:
+            candidates.append(f"{int(ecg_id):05d}.png")
+        except (ValueError, TypeError):
+            pass
+        candidates.append(f"{ecg_id}.jpg")
+
+        for name in candidates:
             p = os.path.join(self.image_dir, name)
             if os.path.exists(p):
                 return p
-        return os.path.join(self.image_dir, f"{ecg_id}.png")
+        raise FileNotFoundError(
+            f"No rendered image for record {ecg_id!r} in {self.image_dir} "
+            f"(tried {candidates}). Run the dataset's data-prep script first."
+        )
 
     def __getitem__(self, i):
         img = Image.open(self._path(self.ids[i])).convert("RGB")

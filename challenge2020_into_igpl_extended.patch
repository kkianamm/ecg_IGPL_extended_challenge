Subject: [PATCH 3/4] Detach logged LMC scalar in mergetune module

float() on a requires_grad tensor emitted a UserWarning every step.
---
 modules/mergetune_module.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/modules/mergetune_module.py b/modules/mergetune_module.py
index 8e6bfcb..1213745 100644
--- a/modules/mergetune_module.py
+++ b/modules/mergetune_module.py
@@ -69,4 +69,4 @@ class MergeTuneModule(AdaptationModule):
             line_loss = line_loss + F.binary_cross_entropy_with_logits(
                 logits_mid, bctx.targets.float()) / len(self.line_samples)
 
-        return self.w_lmc * line_loss, {"lmc": float(line_loss)}
+        return self.w_lmc * line_loss, {"lmc": float(line_loss.detach())}

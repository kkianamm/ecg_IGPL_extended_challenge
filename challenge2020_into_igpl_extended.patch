+
+
+def dataset_label():
+    """Human-readable name of the active dataset, for report headers."""
+    if getattr(C, "DATASET", "ptbxl") == "challenge2020":
+        return f"Challenge 2020 ({len(C.CLASSES)} {C.C2020_CLASS_SET} classes)"
+    return "PTB-XL"

From 5ba49a720ddab18829cc0644fa6d17a10835ee61 Mon Sep 17 00:00:00 2001
From: x <x>
Date: Thu, 23 Jul 2026 22:54:15 +0000
Subject: [PATCH 2/4] Fix image lookup for non-integer record IDs; label report
 headers by dataset
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

ECGImageDataset._path built its candidate tuple eagerly, so int('A0147')
raised before the loop could test 'A0147.png' — which exists. Candidates
are now built lazily and a genuinely missing image raises FileNotFoundError
naming the record and directory instead of failing later inside PIL.

Report headers said 'PTB-XL test fold' regardless of the active dataset;
they now use labels_io.dataset_label().
---
 ipl/data.py         | 18 ++++++++++++++++--
 labels_io.py        |  7 +++++++
 train_biomedcoop.py |  4 ++--
 train_compose.py    |  3 ++-
 zero_shot_eval.py   |  4 ++--
 5 files changed, 29 insertions(+), 7 deletions(-)

diff --git a/ipl/data.py b/ipl/data.py
index 04e3fd7..04ae625 100644
--- a/ipl/data.py
+++ b/ipl/data.py
@@ -169,11 +169,25 @@ class ECGImageDataset(Dataset):
         return len(self.ids)
 
     def _path(self, ecg_id):
-        for name in (f"{ecg_id}.png", f"{int(ecg_id):05d}.png", f"{ecg_id}.jpg"):
+        # Candidates are built lazily: PTB-XL ids are integers and rendered
+        # zero-padded, but Challenge 2020 ids are strings ('A0147', 'HR00001').
+        # Formatting the whole tuple eagerly made int('A0147') raise before the
+        # loop could test the name that actually exists.
+        candidates = [f"{ecg_id}.png"]
+        try:
+            candidates.append(f"{int(ecg_id):05d}.png")
+        except (ValueError, TypeError):
+            pass
+        candidates.append(f"{ecg_id}.jpg")
+
+        for name in candidates:
             p = os.path.join(self.image_dir, name)
             if os.path.exists(p):
                 return p
-        return os.path.join(self.image_dir, f"{ecg_id}.png")
+        raise FileNotFoundError(
+            f"No rendered image for record {ecg_id!r} in {self.image_dir} "
+            f"(tried {candidates}). Run the dataset's data-prep script first."
+        )
 
     def __getitem__(self, i):
         img = Image.open(self._path(self.ids[i])).convert("RGB")
